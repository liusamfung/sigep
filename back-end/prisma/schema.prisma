datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
   previewFeatures = ["driverAdapters"]
}

model Pabellon {
  id        String   @id @default(uuid())
  nombre    String   @unique
  celdas    Celda[]
  createdAt DateTime @default(now())
}

model Celda {
  id         String   @id @default(uuid())
  codigo     String   @unique // Ej: "A-101"
  pabellonId String
  pabellon   Pabellon @relation(fields: [pabellonId], references: [id], onDelete: Cascade)
  presos     Preso[]
}

model Preso {
  id          String       @id @default(uuid())
  codigoUnico String       @unique // Código o DNI del interno
  nombre      String
  apellido    String
  estado      EstadoPreso  @default(ACTIVO) // Para la baja lógica (RF03)
  huellaToken String?      @unique // ID único de huella simulado (RF07)
  celdaId     String
  celda       Celda        @relation(fields: [celdaId], references: [id])
  asistencias Asistencia[]
  createdAt   DateTime     @default(now())
}

model Asistencia {
  id        String           @id @default(uuid())
  presoId   String
  preso     Preso            @relation(fields: [presoId], references: [id], onDelete: Cascade)
  fechaHora DateTime         @default(now())
  estado    EstadoAsistencia @default(PRESENTE)
}

enum EstadoPreso {
  ACTIVO
  INACTIVO
}

enum EstadoAsistencia {
  PRESENTE
  AUSENTE
  FUGA
}
